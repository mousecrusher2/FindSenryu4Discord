# Build stage
FROM golang:1.26-alpine@sha256:7a3e50096189ad57c9f9f865e7e4aa8585ed1585248513dc5cda498e2f41812c AS builder

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o findsenryu .

# Runtime stage
FROM gcr.io/distroless/static-debian13:nonroot@sha256:963fa6c544fe5ce420f1f54fb88b6fb01479f054c8056d0f74cc2c6000df5240

WORKDIR /app
COPY --from=builder /build/findsenryu /app/findsenryu
ENV GODEBUG=disablethp=1

ENTRYPOINT ["/app/findsenryu"]
CMD ["bot"]
